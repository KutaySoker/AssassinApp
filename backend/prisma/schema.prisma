generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ZAFİYET TARAMASI (SCAN) MİMARİSİ
// ==========================================
model ScanHistory {
  id        String   @id @default(uuid())
  startedAt DateTime @default(now())
  status    String   // "COMPLETED", "FAILED", "SCANNING"
  
  // YENİ EKLENEN: Ajan Kimliği
  agentId   String   @default("GHOST-AGENT")
  
  apps      DiscoveredApp[]
}

model DiscoveredApp {
  id          String   @id @default(uuid())
  name        String
  version     String
  vendor      String?
  path        String?  
  cpeString   String?  
  scanId      String
  scan        ScanHistory @relation(fields: [scanId], references: [id], onDelete: Cascade)
  vulnerabilities Vulnerability[]

  @@unique([name, version], name: "app_unique")
}

model Vulnerability {
  id          String   @id @default(uuid())
  cveId       String
  description String?
  severity    String?
  score       Float?
  publishedAt DateTime?
  appId       String
  app         DiscoveredApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([cveId, appId], name: "cve_app_unique")
}

// ==========================================
// 2. RECON (SUBDOMAIN KEŞİF) MİMARİSİ
// ==========================================
model ReconHistory {
  id           String      @id 
  targetDomain String      
  startedAt    DateTime    @default(now())
  agentId      String      @default("GHOST-AGENT")
  
  subdomains   Subdomain[]
}

model Subdomain {
  id          String       @id @default(uuid())
  url         String
  status      Int?         
  title       String?      
  server      String?      
  
  reconId     String
  recon       ReconHistory @relation(fields: [reconId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. GÜNCELLEME (VERSİYON KONTROL) MİMARİSİ
// ==========================================
model UpdateHistory {
  id          String       @id 
  startedAt   DateTime     @default(now())
  agentId     String       @default("GHOST-AGENT")
  
  apps        UpdateApp[]
}

model UpdateApp {
  id             String        @id @default(uuid())
  name           String        
  currentVersion String?       
  latestVersion  String?       
  
  updateId       String
  update         UpdateHistory @relation(fields: [updateId], references: [id], onDelete: Cascade)
}

// ==========================================
// 4. GENEL LOGLAR (Geçmiş Ekranı Vitrini)
// ==========================================
model OperationLog {
  id        String   @id @default(uuid())
  agentId   String   @default("GHOST-AGENT")
  status    String
  message   String
  apps      Json?    
  createdAt DateTime @default(now())
}